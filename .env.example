# Stripe secret key (starts with sk_test_ or sk_live_).
# Get one at https://dashboard.stripe.com/apikeys
# If unset, checkout runs in demo mode: no payment is taken and the
# user is sent straight to the order-confirmation page.
STRIPE_SECRET_KEY=

# Public site URL used for payment redirect links (optional; the
# request origin is used when available).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
